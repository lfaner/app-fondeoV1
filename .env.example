FLASK_ENV=development

# Flask
SECRET_KEY=cambia-esto-por-una-clave-segura-y-larga

# PostgreSQL
DATABASE_URL=postgresql://usuario:password@localhost:5432/fondeo

# Archivos subidos (dejar vacío para usar carpeta uploads/ dentro del proyecto)
UPLOAD_FOLDER=

# API Aunesa / Becerra
AUNESA_USERNAME=tu_usuario
AUNESA_PASSWORD=tu_password
AUNESA_HOST=https://becerra.aunesa.com/Irmo
AUNESA_CLIENT_ID=

# Tipo de cambio USD MEP
USD_MEP=1168

# Email (Flask-Mail) — para verificación de cuenta y reset de contraseña
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=tu_cuenta@gmail.com
MAIL_PASSWORD=tu_app_password_de_gmail
MAIL_DEFAULT_SENDER=CGB Fondeos <tu_cuenta@gmail.com>
